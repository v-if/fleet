# Database (Phase 1: local SQLite — Supabase PostgreSQL URL로 교체 가능)
DATABASE_URL="file:./dev.db"

# Supabase (Phase 4 인증·배포 시 설정)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vehicle data provider: mock | tesla
VEHICLE_DATA_PROVIDER=mock

# Tesla Fleet API (Phase 3)
TESLA_FLEET_API_CLIENT_ID=
TESLA_FLEET_API_CLIENT_SECRET=
TESLA_FLEET_API_REDIRECT_URI=

# Kakao Maps (Phase 2)
NEXT_PUBLIC_KAKAO_MAP_KEY=
