# Database (Phase 3.6: Supabase PostgreSQL)
# Transaction pooler — Vercel serverless / 앱 런타임용 (포트 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct / migrate — Session pooler (5432). Direct host(db.xxx.supabase.co) 차단 시 pooler 사용
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Supabase (Phase 4 인증 시 설정)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vehicle data provider: mock | tesla
VEHICLE_DATA_PROVIDER=mock

# Tesla Fleet API (Phase 3 — OAuth / Phase 3.5 — Partner Register)
TESLA_FLEET_API_CLIENT_ID=
TESLA_FLEET_API_CLIENT_SECRET=
TESLA_FLEET_API_REDIRECT_URI=http://localhost:3000/api/auth/tesla/callback
TESLA_FLEET_API_REGION=na
TESLA_SYNC_POLL_INTERVAL_MINUTES=3
TESLA_SYNC_CRON_SECRET=

# Tesla Telemetry
TESLA_TELEMETRY_ENABLED=true
# webhook 인증 — Vercel TESLA_TELEMETRY_WEBHOOK_SECRET 과 Fly FMS_WEBHOOK_SECRET 과 동일 값
TESLA_TELEMETRY_WEBHOOK_SECRET=
TESLA_TELEMETRY_STALE_AFTER_SECONDS=300
TESLA_TELEMETRY_FRESHNESS_SECONDS=120
# 차량 상세 Telemetry 수신 로그(개발) — true/1 ON, false/0 OFF, 미설정 시 non-production만 ON
# NEXT_PUBLIC_TELEMETRY_VALUE_MONITOR=true
TESLA_REST_AUTO_SYNC_ENABLED=false
# Phase 4.4 — wake 후 vehicle_data 쿨다운(분) · READY 시 Baseline 자동 1회
TESLA_REST_WAKE_COOLDOWN_MINUTES=30
# Phase BF: 인근 충전소 stale 클리어 거리(km)
TESLA_NEARBY_STALE_DISTANCE_KM=2
TESLA_BASELINE_ON_READY=true
# unlink 시 partner token (선택)
TESLA_PARTNER_TOKEN=
# 재연결 시 fleet_telemetry_config create — Vehicle Command Proxy (필수)
# Production: https://bori-cmd-proxy.fly.dev  (path·trailing slash 없음) — docs/handoff-fms.md
TESLA_VEHICLE_COMMAND_PROXY_URL=https://bori-cmd-proxy.fly.dev
TELEMETRY_PUBLIC_HOST=telemetry.bori-fleet.shop
# TESLA_TELEMETRY_CA_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# ↑ Telemetry/bori-telemetry와 동일본 (신규 CA 금지)
# status/process API — Fly FMS_CRON_SECRET 과 동일 값
TESLA_SYNC_CRON_SECRET=
NEXT_PUBLIC_APP_URL=https://bori-fleet.shop

# Phase 3.5: Partner Register 시 사용할 배포 도메인 (scheme 제외, 예: bori-fleet.shop)
# TESLA_REGISTER_DOMAIN=bori-fleet.shop

# Naver Maps (Web Dynamic Map) — Client ID만 브라우저에 노출
# https://navermaps.github.io/maps.js.ncp/docs/tutorial-2-Getting-Started.html
# NCP Application → Web Dynamic Map 사용 + Web 서비스 URL에
#   http://localhost , https://bori-fleet.shop 등록 (포트·path 제외)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
# 서버용 API Gateway Secret (지도 SDK에는 불필요 — 절대 NEXT_PUBLIC 금지)
# NAVER_MAP_CLIENT_SECRET=
