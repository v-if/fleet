generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum VehicleStatus {
  ONLINE
  OFFLINE
  ASLEEP
  WARNING
  ALERT
}

enum TelemetryIngressStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DUPLICATE
}

enum TelemetrySource {
  TELEMETRY
  REST
  MIXED
}

enum ChargingStatus {
  CHARGING
  COMPLETE
  DISCONNECTED
  STOPPED
}

enum ServiceStatus {
  OK
  DUE_SOON
  IN_SERVICE
}

enum EventType {
  ALERT
  WARNING
  IDLE
  OFFLINE
}

enum TeslaAccountRole {
  OWNER
  DRIVER
}

enum AuditLogStatus {
  SUCCESS
  FAILURE
  DENIED
}

enum ApiCallDirection {
  INBOUND
  OUTBOUND
}

/// мШ®л≥ілФ© мИШл™Ем£ЉкЄ∞ (мЪінЦЙ мГБнГЬ VehicleStatus мЩА лґДл¶ђ)
enum VehicleLifecycle {
  REGISTERED
  KEY_PENDING
  TELEMETRY_PENDING
  READY
  TELEMETRY_DISCONNECTED
}

/// vehicle_data / м†ЬмЫР REST нШЄмґЬ мВђмЬ† (мњ®лЛ§мЪі¬Јк∞РмВђ)
enum RestSyncReason {
  BASELINE
  WAKE_COOLDOWN
  MANUAL_FALLBACK
  SPECS_REFRESH
  /// TRF-B2: Gear=P м†Хм∞® мЛЬ nearby_charging_sites only
  PARK_NEARBY
}

/// Telemetry мЧ∞лПЩ нХім†Ь мВђмЬ† (Phase 4.5)
enum TelemetryDisconnectReason {
  USER_SOFTWARE
  VK_REMOVED_OFFLINE
  UNLINK
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  createdAt     DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(3)
  teslaAccounts TeslaAccount[]
  auditLogs     AuditLog[]     @relation("AuditActorUser")
  apiCallLogs   ApiCallLog[]   @relation("ApiCallActorUser")
}

model TeslaAccount {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  teslaEmail   String?
  region       String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime          @db.Timestamptz(3)
  scope        String?
  role         TeslaAccountRole?
  linkedAt     DateTime          @default(now()) @db.Timestamptz(3)
  unlinkedAt   DateTime?         @db.Timestamptz(3)
  createdAt    DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime          @updatedAt @db.Timestamptz(3)
  vehicles               Vehicle[]
  auditLogs              AuditLog[]
  apiCallLogs            ApiCallLog[]
  telemetrySubscriptions TelemetrySubscription[]

  @@unique([userId, teslaEmail])
  @@index([userId])
  @@index([unlinkedAt])
}

model SyncMetadata {
  id           String    @id @default("default")
  lastSyncedAt DateTime? @db.Timestamptz(3)
  provider     String?
  usedFallback Boolean   @default(false)
  lastError    String?
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)
}

model TelemetryMetadata {
  id                  String    @id @default("default")
  enabled             Boolean   @default(true)
  lastReceivedAt      DateTime? @db.Timestamptz(3)
  lastProcessedAt     DateTime? @db.Timestamptz(3)
  lastError           String?
  pendingIngressCount Int       @default(0)
  subscriptionCount   Int       @default(0)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(3)
}

model TelemetryIngress {
  id             String                 @id @default(cuid())
  idempotencyKey String                 @unique
  vin            String?
  vehicleId      String?
  vehicle        Vehicle?               @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  payload        Json
  status         TelemetryIngressStatus @default(PENDING)
  errorMessage   String?
  receivedAt     DateTime               @default(now()) @db.Timestamptz(3)
  processedAt    DateTime?              @db.Timestamptz(3)
  createdAt      DateTime               @default(now()) @db.Timestamptz(3)

  @@index([status, receivedAt])
  @@index([vin])
  @@index([vehicleId])
}

model TelemetrySubscription {
  id               String                      @id @default(cuid())
  vehicleId        String                      @unique
  vehicle          Vehicle                     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vin              String
  teslaAccountId   String?
  teslaAccount     TeslaAccount?               @relation(fields: [teslaAccountId], references: [id], onDelete: SetNull)
  active           Boolean                     @default(true)
  configSynced     Boolean                     @default(false)
  configCheckedAt  DateTime?                   @db.Timestamptz(3)
  subscribedAt     DateTime                    @default(now()) @db.Timestamptz(3)
  unsubscribedAt   DateTime?                   @db.Timestamptz(3)
  disconnectedAt   DateTime?                   @db.Timestamptz(3)
  disconnectReason TelemetryDisconnectReason?
  lastError        String?
  createdAt        DateTime                    @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime                    @updatedAt @db.Timestamptz(3)

  @@index([vin])
  @@index([teslaAccountId])
  @@index([active])
  @@index([disconnectReason])
}

model Vehicle {
  id               String         @id @default(cuid())
  plateNumber      String         @unique
  model            String
  year             Int
  oemVehicleId     String?
  teslaAccountId   String?
  teslaAccount     TeslaAccount?  @relation(fields: [teslaAccountId], references: [id], onDelete: SetNull)
  /// vehicle_config.car_type (м†Хм†Б)
  carType          String?
  /// vehicle_config.trim_badging (м†Хм†Б)
  trimBadging      String?
  /// vehicle_config.exterior_color (м†Хм†Б)
  exteriorColor    String?
  /// Fleet vehicles.display_name (м§Ам†Хм†Б)
  teslaDisplayName String?
  /// vehicle_state.car_version вАФ REST-1 Version (TRF-B1 V-A)
  firmwareVersion  String?
  /// vehicle_config.roof_color
  roofColor        String?
  /// vehicle_config.wheel_type
  wheelType        String?
  /// vehicle_config.charge_port_type (нПђнКЄ кЈЬк≤© ¬Ј лђЄ мЧіл¶Љк≥Љ л≥Дк∞Ь)
  chargePortType   String?
  /// vehicle_config.driver_assist (AP HW)
  driverAssist     String?
  /// vehicle_config.exterior_trim
  exteriorTrim     String?
  /// vehicle_config нХДнД∞ JSON (TRF-B1 Tier C)
  vehicleConfigJson Json?
  /// Fleet list id_s
  teslaVehicleId   String?
  /// Fleet access_type (OWNER/DRIVER вА¶)
  accessType       String?
  /// м†ЬмЫР лІИмІАлІЙ м†АмЮ• мЛЬк∞Б
  specsSyncedAt    DateTime?      @db.Timestamptz(3)
  /// кіАл¶ђмЮР мИШлПЩ нСЬмЛЬл™Е м†АмЮ• мЛЬк∞Б (nullмЭіл©і Tesla deriveл°Ь plateNumber к∞±мЛ† к∞АлК•)
  plateNumberEditedAt DateTime?   @db.Timestamptz(3)
  unlinkedAt       DateTime?      @db.Timestamptz(3)
  isDeleted        Boolean        @default(false)
  createdAt        DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(3)
  snapshots              VehicleSnapshot[]
  events                 VehicleEvent[]
  auditLogs              AuditLog[]
  apiCallLogs            ApiCallLog[]
  telemetryIngress       TelemetryIngress[]
  telemetrySubscription  TelemetrySubscription?
  syncState              VehicleSyncState?

  @@unique([teslaAccountId, oemVehicleId])
  @@index([teslaAccountId])
  @@index([unlinkedAt])
  @@index([carType])
}

/// нХШмЭілЄМл¶ђлУЬ мШ®л≥ілФ©¬Јмњ®лЛ§мЪі SoT (Vehicle 1:1)
model VehicleSyncState {
  vehicleId                 String           @id
  vehicle                   Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  lifecycle                 VehicleLifecycle @default(REGISTERED)
  virtualKeyConfirmedAt     DateTime?        @db.Timestamptz(3)
  telemetryConfigSyncedAt   DateTime?        @db.Timestamptz(3)
  baselineCompletedAt       DateTime?        @db.Timestamptz(3)
  baselineLastError         String?
  lastRestSyncAt            DateTime?        @db.Timestamptz(3)
  lastRestSyncReason        RestSyncReason?
  lastWakeDetectedAt        DateTime?        @db.Timestamptz(3)
  updatedAt                 DateTime         @updatedAt @db.Timestamptz(3)

  @@index([lifecycle])
  @@index([lastRestSyncAt])
}

model VehicleSnapshot {
  id                  String         @id @default(cuid())
  vehicleId           String
  vehicle             Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude            Float?
  longitude           Float?
  batteryPercent      Float?
  rangeKm             Float?
  ignitionOn          Boolean?
  status              VehicleStatus?
  chargingStatus      ChargingStatus?
  odometerKm          Float?
  /// charge_state.charge_limit_soc (%)
  chargeLimitSoc      Float?
  /// charge_state.charger_power (kW)
  chargerPowerKw      Float?
  /// Telemetry AC/DC вАФ `AC`|`DC` ¬Ј RESTлКФ null(лѓЄмГБ)
  chargingPowerKind   String?
  /// drive_state.shift_state / Telemetry Gear вАФ м†ХкЈЬнЩФ P|R|N|D
  shiftState          String?
  locked              Boolean?
  doorsOpen           Boolean?
  windowsOpen         Boolean?
  /// vehicle_state df/dr/pf/pr (к∞Ьл≥Д лПДмЦі)
  doorDfOpen          Boolean?
  doorDrOpen          Boolean?
  doorPfOpen          Boolean?
  doorPrOpen          Boolean?
  /// frunk / trunk
  frontTrunkOpen      Boolean?
  rearTrunkOpen       Boolean?
  insideTempC         Float?
  outsideTempC        Float?
  climateOn           Boolean?
  tpmsFrontLeft       Float?
  tpmsFrontRight      Float?
  tpmsRearLeft        Float?
  tpmsRearRight       Float?
  /// CAF P1
  vehicleSpeedKmh     Float?
  gpsHeading          Float?
  detailedChargeState String?
  timeToFullChargeHours Float?
  chargeAmps          Float?
  chargePortDoorOpen  Boolean?
  chargePortLatch     String?
  fastChargerPresent  Boolean?
  tpmsHardWarnings    String?
  tpmsSoftWarnings    String?
  destinationName     String?
  destinationLatitude Float?
  destinationLongitude Float?
  minutesToArrival    Float?
  milesToArrival      Float?
  expectedEnergyPercentAtArrival Float?
  preconditioningEnabled Boolean?
  valetModeEnabled    Boolean?
  serviceModeEnabled  Boolean?
  softwareUpdateDownloadPercent Int?
  softwareUpdateInstallPercent Int?
  softwareUpdateVersion String?
  sentryMode          Boolean?
  serviceStatus       ServiceStatus?
  softwareVersion     String?
  nearbyChargingSites String?
  lastTelemetryAt     DateTime?      @db.Timestamptz(3)
  lastRestSyncAt      DateTime?      @db.Timestamptz(3)
  telemetrySource     TelemetrySource?
  isAsleepInferred    Boolean        @default(false)
  sleepInferredAt     DateTime?      @db.Timestamptz(3)
  lastUpdatedAt       DateTime       @default(now()) @db.Timestamptz(3)
  createdAt           DateTime       @default(now()) @db.Timestamptz(3)

  @@index([vehicleId])
  @@index([lastUpdatedAt])
  @@index([lastTelemetryAt])
}

model VehicleEvent {
  id         String    @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type       EventType
  message    String
  occurredAt DateTime  @default(now()) @db.Timestamptz(3)
  resolvedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([vehicleId])
  @@index([occurredAt])
}

model AuditLog {
  id             String         @id @default(cuid())
  occurredAt     DateTime       @default(now()) @db.Timestamptz(3)
  actorUserId    String?
  actorUser      User?          @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail     String?
  action         String
  targetType     String?
  targetId       String?
  vehicleId      String?
  vehicle        Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  teslaAccountId String?
  teslaAccount   TeslaAccount?  @relation(fields: [teslaAccountId], references: [id], onDelete: SetNull)
  requestId      String?
  status         AuditLogStatus
  summary        String
  metadata       Json?
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)
  apiCallLogs    ApiCallLog[]

  @@index([actorUserId])
  @@index([vehicleId])
  @@index([teslaAccountId])
  @@index([requestId])
  @@index([action])
  @@index([occurredAt])
}

model ApiCallLog {
  id              String           @id @default(cuid())
  occurredAt      DateTime         @default(now()) @db.Timestamptz(3)
  direction       ApiCallDirection
  system          String
  requestId       String?
  auditLogId      String?
  auditLog        AuditLog?        @relation(fields: [auditLogId], references: [id], onDelete: SetNull)
  actorUserId     String?
  actorUser       User?            @relation("ApiCallActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  teslaAccountId  String?
  teslaAccount    TeslaAccount?    @relation(fields: [teslaAccountId], references: [id], onDelete: SetNull)
  vehicleId       String?
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  method          String
  url             String
  path            String?
  statusCode      Int?
  success         Boolean
  durationMs      Int?
  requestHeaders  Json?
  requestBody     Json?
  responseHeaders Json?
  responseBody    Json?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime         @default(now()) @db.Timestamptz(3)

  @@index([requestId])
  @@index([auditLogId])
  @@index([actorUserId])
  @@index([teslaAccountId])
  @@index([vehicleId])
  @@index([system])
  @@index([occurredAt])
}

/// NCS вАФ nearby REST мФ®лУЬ мґЬм≤Ш
enum ChargingStationSource {
  TESLA_NEARBY
}

/// NCS вАФ Tesla nearby site type
enum ChargingStationSiteType {
  destination
  supercharger
}

model ChargingStation {
  id                  String                  @id @default(cuid())
  source              ChargingStationSource   @default(TESLA_NEARBY)
  siteType            ChargingStationSiteType
  name                String
  nameKey             String
  latitude            Float
  longitude           Float
  /// unique: lat.round(5):lng.round(5):siteType
  geoKey              String                  @unique
  totalStalls         Int?
  lastAvailableStalls Int?
  siteClosed          Boolean?
  lastSeenAt          DateTime                @db.Timestamptz(3)
  hitCount            Int                     @default(1)
  createdAt           DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime                @updatedAt @db.Timestamptz(3)

  @@index([latitude, longitude])
  @@index([lastSeenAt])
}
