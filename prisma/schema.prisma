generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum VehicleStatus {
  ONLINE
  OFFLINE
  WARNING
  ALERT
}

enum ChargingStatus {
  CHARGING
  COMPLETE
  DISCONNECTED
  STOPPED
}

enum ServiceStatus {
  OK
  DUE_SOON
  IN_SERVICE
}

enum EventType {
  ALERT
  WARNING
  IDLE
  OFFLINE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeslaOAuthToken {
  id           String   @id @default(cuid())
  accountKey   String   @unique @default("default")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SyncMetadata {
  id           String   @id @default("default")
  lastSyncedAt DateTime?
  provider     String?
  usedFallback Boolean  @default(false)
  lastError    String?
  updatedAt    DateTime @updatedAt
}

model Vehicle {
  id           String   @id @default(cuid())
  plateNumber  String   @unique
  model        String
  year         Int
  oemVehicleId String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  snapshots VehicleSnapshot[]
  events    VehicleEvent[]
}

model VehicleSnapshot {
  id             String          @id @default(cuid())
  vehicleId      String
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude       Float
  longitude      Float
  batteryPercent Float?
  rangeKm        Float?
  ignitionOn     Boolean         @default(false)
  status         VehicleStatus   @default(OFFLINE)
  chargingStatus ChargingStatus  @default(DISCONNECTED)
  odometerKm     Float?
  locked         Boolean         @default(true)
  doorsOpen      Boolean         @default(false)
  windowsOpen    Boolean         @default(false)
  insideTempC    Float?
  outsideTempC   Float?
  climateOn      Boolean         @default(false)
  tpmsFrontLeft  Float?
  tpmsFrontRight Float?
  tpmsRearLeft   Float?
  tpmsRearRight  Float?
  sentryMode     Boolean         @default(false)
  serviceStatus  ServiceStatus   @default(OK)
  softwareVersion String?
  nearbyChargingSites String?
  lastUpdatedAt  DateTime        @default(now())
  createdAt      DateTime        @default(now())

  @@index([vehicleId])
  @@index([lastUpdatedAt])
}

model VehicleEvent {
  id         String    @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type       EventType
  message    String
  occurredAt DateTime  @default(now())
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([vehicleId])
  @@index([occurredAt])
}
