generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum VehicleStatus {
  ONLINE
  OFFLINE
  ASLEEP
  WARNING
  ALERT
}

enum TelemetryIngressStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DUPLICATE
}

enum TelemetrySource {
  TELEMETRY
  REST
  MIXED
}

enum ChargingStatus {
  CHARGING
  COMPLETE
  DISCONNECTED
  STOPPED
}

enum ServiceStatus {
  OK
  DUE_SOON
  IN_SERVICE
}

enum EventType {
  ALERT
  WARNING
  IDLE
  OFFLINE
}

enum TeslaAccountRole {
  OWNER
  DRIVER
}

enum AuditLogStatus {
  SUCCESS
  FAILURE
  DENIED
}

enum ApiCallDirection {
  INBOUND
  OUTBOUND
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  createdAt     DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(3)
  teslaAccounts TeslaAccount[]
  auditLogs     AuditLog[]     @relation("AuditActorUser")
  apiCallLogs   ApiCallLog[]   @relation("ApiCallActorUser")
}

model TeslaAccount {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  teslaEmail   String?
  region       String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime          @db.Timestamptz(3)
  scope        String?
  role         TeslaAccountRole?
  linkedAt     DateTime          @default(now()) @db.Timestamptz(3)
  unlinkedAt   DateTime?         @db.Timestamptz(3)
  createdAt    DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime          @updatedAt @db.Timestamptz(3)
  vehicles               Vehicle[]
  auditLogs              AuditLog[]
  apiCallLogs            ApiCallLog[]
  telemetrySubscriptions TelemetrySubscription[]

  @@unique([userId, teslaEmail])
  @@index([userId])
  @@index([unlinkedAt])
}

model SyncMetadata {
  id           String    @id @default("default")
  lastSyncedAt DateTime? @db.Timestamptz(3)
  provider     String?
  usedFallback Boolean   @default(false)
  lastError    String?
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)
}

model TelemetryMetadata {
  id                  String    @id @default("default")
  enabled             Boolean   @default(true)
  lastReceivedAt      DateTime? @db.Timestamptz(3)
  lastProcessedAt     DateTime? @db.Timestamptz(3)
  lastError           String?
  pendingIngressCount Int       @default(0)
  subscriptionCount   Int       @default(0)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(3)
}

model TelemetryIngress {
  id             String                 @id @default(cuid())
  idempotencyKey String                 @unique
  vin            String?
  vehicleId      String?
  vehicle        Vehicle?               @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  payload        Json
  status         TelemetryIngressStatus @default(PENDING)
  errorMessage   String?
  receivedAt     DateTime               @default(now()) @db.Timestamptz(3)
  processedAt    DateTime?              @db.Timestamptz(3)
  createdAt      DateTime               @default(now()) @db.Timestamptz(3)

  @@index([status, receivedAt])
  @@index([vin])
  @@index([vehicleId])
}

model TelemetrySubscription {
  id             String        @id @default(cuid())
  vehicleId      String        @unique
  vehicle        Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  vin            String
  teslaAccountId String?
  teslaAccount   TeslaAccount? @relation(fields: [teslaAccountId], references: [id], onDelete: SetNull)
  active         Boolean       @default(true)
  subscribedAt   DateTime      @default(now()) @db.Timestamptz(3)
  unsubscribedAt DateTime?     @db.Timestamptz(3)
  lastError      String?
  createdAt      DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(3)

  @@index([vin])
  @@index([teslaAccountId])
  @@index([active])
}

model Vehicle {
  id             String           @id @default(cuid())
  plateNumber    String           @unique
  model          String
  year           Int
  oemVehicleId   String?
  teslaAccountId String?
  teslaAccount   TeslaAccount?    @relation(fields: [teslaAccountId], references: [id], onDelete: SetNull)
  unlinkedAt     DateTime?         @db.Timestamptz(3)
  isDeleted      Boolean          @default(false)
  createdAt      DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @db.Timestamptz(3)
  snapshots              VehicleSnapshot[]
  events                 VehicleEvent[]
  auditLogs              AuditLog[]
  apiCallLogs            ApiCallLog[]
  telemetryIngress       TelemetryIngress[]
  telemetrySubscription  TelemetrySubscription?

  @@unique([teslaAccountId, oemVehicleId])
  @@index([teslaAccountId])
  @@index([unlinkedAt])
}

model VehicleSnapshot {
  id                  String         @id @default(cuid())
  vehicleId           String
  vehicle             Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  latitude            Float?
  longitude           Float?
  batteryPercent      Float?
  rangeKm             Float?
  ignitionOn          Boolean?
  status              VehicleStatus?
  chargingStatus      ChargingStatus?
  odometerKm          Float?
  locked              Boolean?
  doorsOpen           Boolean?
  windowsOpen         Boolean?
  insideTempC         Float?
  outsideTempC        Float?
  climateOn           Boolean?
  tpmsFrontLeft       Float?
  tpmsFrontRight      Float?
  tpmsRearLeft        Float?
  tpmsRearRight       Float?
  sentryMode          Boolean?
  serviceStatus       ServiceStatus?
  softwareVersion     String?
  nearbyChargingSites String?
  lastTelemetryAt     DateTime?      @db.Timestamptz(3)
  lastRestSyncAt      DateTime?      @db.Timestamptz(3)
  telemetrySource     TelemetrySource?
  isAsleepInferred    Boolean        @default(false)
  sleepInferredAt     DateTime?      @db.Timestamptz(3)
  lastUpdatedAt       DateTime       @default(now()) @db.Timestamptz(3)
  createdAt           DateTime       @default(now()) @db.Timestamptz(3)

  @@index([vehicleId])
  @@index([lastUpdatedAt])
  @@index([lastTelemetryAt])
}

model VehicleEvent {
  id         String    @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type       EventType
  message    String
  occurredAt DateTime  @default(now()) @db.Timestamptz(3)
  resolvedAt DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([vehicleId])
  @@index([occurredAt])
}

model AuditLog {
  id             String         @id @default(cuid())
  occurredAt     DateTime       @default(now()) @db.Timestamptz(3)
  actorUserId    String?
  actorUser      User?          @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail     String?
  action         String
  targetType     String?
  targetId       String?
  vehicleId      String?
  vehicle        Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  teslaAccountId String?
  teslaAccount   TeslaAccount?  @relation(fields: [teslaAccountId], references: [id], onDelete: SetNull)
  requestId      String?
  status         AuditLogStatus
  summary        String
  metadata       Json?
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)
  apiCallLogs    ApiCallLog[]

  @@index([actorUserId])
  @@index([vehicleId])
  @@index([teslaAccountId])
  @@index([requestId])
  @@index([action])
  @@index([occurredAt])
}

model ApiCallLog {
  id              String           @id @default(cuid())
  occurredAt      DateTime         @default(now()) @db.Timestamptz(3)
  direction       ApiCallDirection
  system          String
  requestId       String?
  auditLogId      String?
  auditLog        AuditLog?        @relation(fields: [auditLogId], references: [id], onDelete: SetNull)
  actorUserId     String?
  actorUser       User?            @relation("ApiCallActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  teslaAccountId  String?
  teslaAccount    TeslaAccount?    @relation(fields: [teslaAccountId], references: [id], onDelete: SetNull)
  vehicleId       String?
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  method          String
  url             String
  path            String?
  statusCode      Int?
  success         Boolean
  durationMs      Int?
  requestHeaders  Json?
  requestBody     Json?
  responseHeaders Json?
  responseBody    Json?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime         @default(now()) @db.Timestamptz(3)

  @@index([requestId])
  @@index([auditLogId])
  @@index([actorUserId])
  @@index([teslaAccountId])
  @@index([vehicleId])
  @@index([system])
  @@index([occurredAt])
}
